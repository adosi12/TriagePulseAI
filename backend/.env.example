# ═══════════════════════════════════════════════════════════════════════
#  Sentinel — Environment Configuration
#  ─────────────────────────────────────────────────────────────────────
#  TEAM: Commit this file. Never commit .env
#  LOCAL: Copy this file → .env, then fill in your real values.
#
#    cp .env.example .env
#
#  All values here are placeholders. Replace <PLACEHOLDER> tokens with
#  real credentials in your local .env only.
# ═══════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────
#  LLM — Anthropic Claude
#  Get token: https://console.anthropic.com → API Keys
# ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
ANTHROPIC_MODEL=claude-3-5-haiku-20241022


# ───────────────────────────────────────────────────────────────────────
#  Ticketing — Jira
#  Get token: https://id.atlassian.com → Security → API tokens
# ───────────────────────────────────────────────────────────────────────
JIRA_URL=https://<YOUR_ORG>.atlassian.net
JIRA_EMAIL=<YOUR_JIRA_EMAIL>
JIRA_TOKEN=<YOUR_JIRA_API_TOKEN>
JIRA_PROJECT_KEY=SENT


# ───────────────────────────────────────────────────────────────────────
#  Source Control — GitHub
#  Get token: https://github.com/settings/tokens (scope: repo)
# ───────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=<YOUR_GITHUB_PERSONAL_ACCESS_TOKEN>
GITHUB_ORG=<YOUR_GITHUB_ORG_OR_USERNAME>
GITHUB_REPO=<YOUR_REPO_NAME>


# ───────────────────────────────────────────────────────────────────────
#  Source Control — Bitbucket
#  Get token: https://bitbucket.org/account/settings/app-passwords/
# ───────────────────────────────────────────────────────────────────────
BITBUCKET_URL=https://bitbucket.org
BITBUCKET_USERNAME=<YOUR_BITBUCKET_USERNAME>
BITBUCKET_TOKEN=<YOUR_BITBUCKET_APP_PASSWORD>
BITBUCKET_WORKSPACE=<YOUR_BITBUCKET_WORKSPACE_SLUG>
BITBUCKET_REPO=<YOUR_BITBUCKET_REPO_SLUG>


# ───────────────────────────────────────────────────────────────────────
#  Notifications — Slack
#  Get webhook: https://api.slack.com/apps → Incoming Webhooks
#  Leave blank to use the MOCKED client (logs to console)
# ───────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#sentinel-alerts


# ───────────────────────────────────────────────────────────────────────
#  Incident Management — ServiceNow (future integration)
#  Leave blank to skip (not required for hackathon demo)
# ───────────────────────────────────────────────────────────────────────
SERVICENOW_INSTANCE=<YOUR_INSTANCE>.service-now.com
SERVICENOW_USERNAME=<YOUR_SERVICENOW_USERNAME>
SERVICENOW_PASSWORD=<YOUR_SERVICENOW_PASSWORD>


# ───────────────────────────────────────────────────────────────────────
#  Pipeline Tuning (safe defaults — change only if needed)
# ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.65
MANUAL_TRIAGE_MIN_DEFAULT=40
